# Execution mode: shadow (log only), paper (simulated), live (real trades)
PM_EXECUTION_MODE=shadow

# Polymarket CLOB API credentials
# Get these from: https://docs.polymarket.com/#authentication
PM_POLYMARKET_API_KEY=
PM_POLYMARKET_API_SECRET=
PM_POLYMARKET_API_PASSPHRASE=
PM_POLYMARKET_WALLET_PRIVATE_KEY=

# Database
PM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/polymarket_bot

# Market Discovery
PM_DISCOVERY_INTERVAL_SECONDS=300
PM_MIN_VOLUME_USD=50000
PM_MIN_LIQUIDITY_USD=10000

# LLM Batch Analysis
PM_LLM_BATCH_INTERVAL_SECONDS=900
PM_LLM_BATCH_SIZE=20
PM_LLM_SIGNAL_TTL_SECONDS=1800

# Strategy
PM_STRATEGY_LOOP_INTERVAL_SECONDS=30
PM_MIN_EDGE_THRESHOLD=0.05

# Risk Management
PM_MAX_POSITION_PER_MARKET_USD=500
PM_MAX_PORTFOLIO_EXPOSURE_PCT=0.80
PM_MAX_PORTFOLIO_DRAWDOWN_PCT=0.15
PM_MAX_DAILY_LOSS_USD=200
PM_KELLY_FRACTION=0.25

# Logging
PM_LOG_LEVEL=INFO
